{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.php)", "dest": "/$1" },
    { "src": "/style.css",  "dest": "/style.css" },
    { "src": "/app.js",     "dest": "/app.js" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
